# Скопируй этот файл в .env и подставь реальные значения.
# .env в git не коммитится (он в .gitignore).

# База данных PostgreSQL
# Для запуска вне докера: host = localhost
# Внутри docker-compose host будет = postgres (имя сервиса)
DATABASE_URL=postgresql://vitalrank:vitalrank@localhost:5432/vitalrank

# Redis (брокер очереди Celery)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change_me_generate_your_own
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google PageSpeed Insights API
PAGESPEED_API_KEY=your_pagespeed_key_here

# URL фронтенда (для CORS)
FRONTEND_URL=http://localhost:5173
